---
/**
 * Header.astro
 * 左側にロゴ＋グローバルナビ、右側に施設名タブ・SNS・予約ボタン・言語切替・ハンバーガーを配置。
 * ※ スタイルは header.scss で管理
 */

/** このロゴ使います宣伝 */
interface Props {
  currentPath?: string;
}

/** 現在のページ（currentPath）を取得し、無い場合は「/」を使う */
const { currentPath = '/' } = Astro.props;


/** グローバルナビゲーション項目 */
const navItems = [
  { label: 'ABOUT', href: '/about' },
  { label: 'PROJECT', href: '/project' },
  { label: 'CONTACT', href: '/contact' },
];
---


<!-- ========== ヘッダーエリア========== -->
<header class="header" id="siteHeader">
   <div class="header__inner">
    <!-- ========== 左エリア: ロゴ + グローバルナビ ========== -->
     <div class="header__left">
      <a href="/" class="header__logo" id="headerLogo">
        YONEDA HOTEL GROUP
      </a>
      <nav class="header__nav" id="globalNav" aria-label="グローバルナビゲーション">
        <ul class="header__nav-item">
          
        </ul>



