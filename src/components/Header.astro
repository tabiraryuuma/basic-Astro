---
import Button from '../components/Button.astro';
import InstagramIcon from '../assets/SVG/Instagram.svg';
import LineIcon from '../assets/SVG/LINE.svg';
import "../styles/style.scss";

/**
 * Header.astro
 * 左側にロゴ＋グローバルナビ、右側に施設名タブ・SNS・予約ボタン・言語切替・ハンバーガーを配置。
 * ※ スタイルは header.scss で管理
 */

/** このロゴ使います宣伝 */
interface Props {
  currentPath?: string;
}

/** 現在のページ（currentPath）を取得し、無い場合は「/」を使う */
const { currentPath = '/' } = Astro.props;


/** グローバルナビゲーション項目 */
const navItems = [
  { label: 'ABOUT', href: '/about' },
  { label: 'PROJECT', href: '/project' },
  { label: 'CONTACT', href: '/contact' },
];

/** 施設一覧 */
const facilities = [
  { label: 'Itoshima 810', href: '/facility/itoshima-810' },
  { label: 'Itoshima 808', href: '/facility/itoshima-808' },
  { label: 'Tamagawa4', href: '/facility/tamagawa4' },
  { label: 'Okusu3', href: '/facility/okusu3' },
];
---


<!-- ========== ヘッダーエリア========== -->
<header class="header" id="siteHeader">
   <div class="header__inner">
    <!-- ========== 左エリア: ロゴ + グローバルナビ ========== -->
     <div class="header__left">
      <a href="/" class="header__logo" id="headerLogo">
        YONEDA HOTEL GROUP
      </a>
      <nav class="header__nav" id="globalNav" aria-label="グローバルナビゲーション">
        <ul class="header__nav-list">
          {navItems.map((item) => (
            <li class="header__nav-item">
              <a
                href={item.href}
                class:list={[
                  'header__nav-link',
                  { 'is-active': currentPath === item.href },
                ]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <!-- ========== 右エリア: 施設タブ + アクション ========== -->
     <div class="header__right">

      <!-- 施設タブ -->
      <nav class="header__facilities" aria-label="施設一覧">
        <ul class="header__facilities-list"> 
          {facilities.map((facility) => (
            <li class="header__facilities-item">
              <a href={facility.href} class="header__facilities-link">
                {facility.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- SNS アイコン -->
       <div class="header__sns">
        <a 
          href="https://www.instagram.com/"
          class="header__sns-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          >
            <!-- Instagram アイコン（SVG） -->
             <img src={InstagramIcon.src} alt="" class="header__sns-icon" />           
            </a>
          <!-- LINE アイコン（SVG） -->
            <a
             href="https://line.me/..."
             class="header__sns-link"
             target="_blank"
             rel="noopener noreferrer"
             aria-label="LINE"
             >
             <img src={LineIcon.src} alt="" class="header__sns-icon" />           
            </a>
 
        </div>
            <!-- Reserve / 予約 ボタン -->
             <div class="header__reserve">
              <a href="/reserve" class="header__reserve-btn" id="reserveBtn">
                <Button href="#" text="Reserve<span>｜</span>予約"></Button>
              </a>
            </div>
            
            <!-- 言語切替 -->
             <div class="header__lang" id="langSwitch">
              <button
               type="button"
               class="header__lang-btn is-active"
               data-lang="ja"
               aria-label="日本語に切り替え"
              >
               JP
              </button>
              <button
               type="button"
               class="header__lang-btn"
               data-lang="en"
               aria-label="Switch to English"
              >
               EN                                         
              </button>
             </div>
            </div>
  </div>                                                  


  <!-- ==================== SP メニューパネル ==================== -->
  <div class="header__panel" id="menuPanel">
    <!-- 閉じるボタン -->
     <button
       class="header__panel-close"                        
       id="panelCloseButton"
       type="button"
       aria-label="メニューを閉じる"
     >
       <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="28" height="28">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
     </button>

    <!-- パネル内: 施設ボタン -->
     <div class="header__panel-facilities">
      {facilities.map((facility) => (
       <a href={facility.href} class="header__panel-facility-link">
         {facility.label}
        </a>
        ))}
     </div>
     
     <!-- パネル内: 予約ボタン -->
      <div class="header__panel-reserve">
        <a href="/reserve" class="header__panel-reserve-btn">
          <span>Reserve</span>
          <span class="header__panel-reserve-divider" aria-hidden="true"></span>
          <span>予約</span>
        </a>
      </div>
    
 <!------------ パネル内: SNSアイコン ------------>
       <div class="header__panel-sns">
        <a 
          href="https://www.instagram.com/"
          class="header__panel-sns-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
           >
            <!-- Instagram アイコン（SVG） -->
             <img src={InstagramIcon.src} alt="" class="header__sns-icon" />           
            </a>

          <!-- LINE アイコン（SVG） -->
            <a
             href="https://line.me/..."
             class="header__panel-sns-link"
             target="_blank"
             rel="noopener noreferrer"
             aria-label="LINE"
             >
             <img src={LineIcon.src} alt="" class="header__sns-icon" />           
            </a>
          </div>

  <!------------ パネル内: ナビリンク ------------>
    <nav class="header__panel-nav" aria-label="パネルナビゲーション">
      <ul class="header__panel-nav-list">
        {navItems.map((item) => (
        <li class="header__panel-nav-item">
            <a href={item.href} class="header__panel-nav-link">
              {item.label}
            </a>
          </li>
        ))}
      </ul>                                               <!-- ⭐修正: </ul> 追加 -->
      </nav>
  
   <!------------ パネル内: フッター情報 ------------>
   <div class="header__panel-footer">
    <a href="/hotel-consultation" class="header__panel-footer-cta">
      ホテルづくりをお考えの方へ
    </a>
    <div class="header__panel-footer-info">
      <p class="header__panel-footer-company">米田建築工房</p>
      <p class="header__panel-footer-dept">設計部門</p>
      <p class="header__panel-footer-brand">TRUNK DESIGN OFFICE</p>
    </div>
  </div>
</div>





      




