---
// src/components/Card.astro
import '../styles/components/_card.scss';

interface Props {
  title?: string;
  url?: string;
}

const {
  title = "カードタイトル",
  url = "#",
} = Astro.props;
---

<div class="card">
  <p class="card__title">{title}</p>

  <button class="card__button">
    <span class="card__arrow">→</span>
  </button>
</div>
